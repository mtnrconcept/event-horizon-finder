SEARXNG_BIND_ADDRESS=127.0.0.1
SEARXNG_PORT=8080
SEARXNG_PUBLIC_URL=https://search.example.com/
SEARXNG_SECRET=replace-with-at-least-32-random-bytes
SEARXNG_AUTH_TOKEN=replace-with-a-different-long-random-token
SAFE_FETCH_AUTH_TOKEN=replace-with-a-third-independent-long-random-token
SAFE_FETCH_PROXY_URL=https://search.example.com/safe-fetch/v1/fetch
SAFE_FETCH_MAX_RESPONSE_BYTES=5242880
SAFE_FETCH_MAX_CONCURRENCY=32
SAFE_FETCH_TOTAL_TIMEOUT=20s
SAFE_FETCH_DNS_TIMEOUT=3s
SAFE_FETCH_CONNECT_TIMEOUT=5s
SAFE_FETCH_RESPONSE_HEADER_TIMEOUT=8s
CADDY_IMAGE=docker.io/library/caddy:2.11.4-alpine
SEARXNG_IMAGE=ghcr.io/searxng/searxng:2026.5.10-df1f24fb7
VALKEY_IMAGE=docker.io/valkey/valkey:8.1.8-alpine
SAFE_FETCH_GO_IMAGE=docker.io/library/golang:1.25-alpine
SAFE_FETCH_PROXY_IMAGE=globalparty/safe-fetch-proxy:local
