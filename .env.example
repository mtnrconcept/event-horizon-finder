SUPABASE_PROJECT_ID="xtwxmdbobehovnghfkes"
SUPABASE_URL="https://xtwxmdbobehovnghfkes.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<your-publishable-key>"
VITE_SUPABASE_PROJECT_ID="xtwxmdbobehovnghfkes"
VITE_SUPABASE_URL="https://xtwxmdbobehovnghfkes.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-publishable-key>"

# Canonical public origin used by sitemap.xml and MCP citation URLs.
SITE_URL="https://event-horizon-finder.vercel.app"

# Optional: enables the Mapbox free-tier style on /map. Falls back to OpenStreetMap when empty.
VITE_MAPBOX_ACCESS_TOKEN="<your-mapbox-public-token>"
# GitHub/Lovable aliases also supported at build time:
# MAPBOX_API_KEY="<your-mapbox-public-token>"
# MAPBOX_ACCESS_TOKEN="<your-mapbox-public-token>"

# Edge Functions secrets (configure with `supabase secrets set`, never expose in Vite).
# SITE_URL is also used to restrict Stripe Checkout redirects to this trusted origin.
STRIPE_SECRET_KEY="<stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<stripe-webhook-signing-secret>"
OPENAI_API_KEY="<openai-api-key>"
OPENAI_AD_MODEL="gpt-5-mini"
